---
import config from '../data/config.json';

const { leadCapture } = config;
const isActive = leadCapture?.enabled &&
  leadCapture.brevoApiKey !== 'SEU_BREVO_API_KEY_AQUI' &&
  leadCapture.brevoListId > 0;

if (!isActive) return;
---

<div class="lead-capture">
  <div class="lead-capture-inner">
    <p class="lead-magnet-text">🎁 {leadCapture.leadMagnet}</p>
    <form id="lead-form" class="lead-form" novalidate>
      <input
        type="text"
        id="lead-name"
        name="name"
        placeholder="Seu nome"
        required
        autocomplete="given-name"
        class="lead-input"
      />
      <input
        type="email"
        id="lead-email"
        name="email"
        placeholder="Seu melhor e-mail"
        required
        autocomplete="email"
        class="lead-input"
      />
      <button type="submit" class="lead-btn" id="lead-submit">
        Quero receber grátis
      </button>
    </form>
    <p id="lead-success" class="lead-success" hidden>
      ✅ Enviado! Verifique seu e-mail.
    </p>
    <p id="lead-error" class="lead-error" hidden>
      Algo deu errado. Tente novamente.
    </p>
  </div>
</div>

<script define:vars={{ brevoApiKey: leadCapture.brevoApiKey, brevoListId: leadCapture.brevoListId }}>
  const form = document.getElementById('lead-form');
  const submitBtn = document.getElementById('lead-submit');
  const successEl = document.getElementById('lead-success');
  const errorEl = document.getElementById('lead-error');

  form?.addEventListener('submit', async function (e) {
    e.preventDefault();
    const name = document.getElementById('lead-name').value.trim();
    const email = document.getElementById('lead-email').value.trim();
    if (!name || !email) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    errorEl.hidden = true;

    try {
      const res = await fetch('https://api.brevo.com/v3/contacts', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'api-key': brevoApiKey,
        },
        body: JSON.stringify({
          email,
          attributes: { FIRSTNAME: name },
          listIds: [brevoListId],
          updateEnabled: true,
        }),
      });

      if (res.ok || res.status === 204) {
        form.hidden = true;
        successEl.hidden = false;
        if (typeof fbq !== 'undefined') fbq('track', 'Lead');
      } else {
        throw new Error('API error ' + res.status);
      }
    } catch {
      errorEl.hidden = false;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Quero receber grátis';
    }
  });
</script>

<style>
  .lead-capture {
    background: linear-gradient(135deg, #f5ede3, #ede0d0);
    border-radius: 1.25rem;
    padding: 1.5rem 1.25rem;
    margin-bottom: 0.5rem;
    box-shadow: 0 2px 12px rgba(190, 153, 111, 0.15);
  }

  .lead-capture-inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lead-magnet-text {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    color: #3E2F25;
    margin: 0;
    line-height: 1.4;
    text-align: center;
  }

  .lead-form {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .lead-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid #e0cfc0;
    border-radius: 0.65rem;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    color: #3E2F25;
    background: white;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s;
  }

  .lead-input:focus {
    border-color: #be996f;
  }

  .lead-input::placeholder {
    color: #b0998a;
  }

  .lead-btn {
    width: 100%;
    padding: 0.85rem;
    background: #be996f;
    color: white;
    border: none;
    border-radius: 0.65rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
  }

  .lead-btn:hover:not(:disabled) {
    background: #a8845a;
  }

  .lead-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .lead-success {
    text-align: center;
    color: #2EB897;
    font-family: var(--font-sans);
    font-weight: 600;
    margin: 0;
  }

  .lead-error {
    text-align: center;
    color: #e53e3e;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    margin: 0;
  }
</style>
