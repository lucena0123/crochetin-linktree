---
import BaseLayout from '../../layouts/BaseLayout.astro';
import config from '../../data/config.json';

const collshpUrl = 'https://collshp.com/crochetin?share_channel_code=1&view=storefront';

const kits = [
  {
    icon: '🧶',
    title: 'Kit Fio Náutico Premium',
    description: 'Fio resistente e elegante, ideal para as Bags Mari, Atena e Cherry.',
  },
  {
    icon: '🪡',
    title: 'Kit Fio de Malha',
    description: 'Macio e versátil, perfeito para as Bags Ariel e Lieta.',
  },
  {
    icon: '🔗',
    title: 'Acessórios e Alças',
    description: 'Argolas, correntes e alças em metal dourado ou prata.',
  },
  {
    icon: '🎁',
    title: 'Kits Completos',
    description: 'Tudo que você precisa para começar sua bolsa do zero.',
  },
];
---

<BaseLayout
  title="Materiais Crochetin - Kits e Fios para Crochê"
  description="Encontre os melhores fios e materiais para fazer suas bolsas de crochê com qualidade profissional."
>
  <div class="page-header">
    <a href="/" class="back-button" aria-label="Voltar ao início">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </a>
    <div class="header-text">
      <h1 class="page-title">Materiais Crochetin</h1>
      <p class="page-subtitle">Fios e kits selecionados por quem entende</p>
    </div>
    <div class="header-spacer" aria-hidden="true"></div>
  </div>

  <div class="kits-grid">
    {kits.map((kit) => (
      <div class="kit-card">
        <span class="kit-icon">{kit.icon}</span>
        <div class="kit-info">
          <h3 class="kit-title">{kit.title}</h3>
          <p class="kit-description">{kit.description}</p>
        </div>
      </div>
    ))}
  </div>

  <div class="cta-section">
    <p class="cta-text">Todos os materiais disponíveis na loja oficial Crochetin</p>
    <a
      href={collshpUrl}
      class="cta-btn"
      target="_blank"
      rel="noopener noreferrer"
      onclick="if(typeof gtag!=='undefined'){gtag('event','click',{event_category:'materiais',event_label:'collshp_cta'})} if(typeof fbq!=='undefined'){fbq('track','ViewContent',{content_name:'Materiais Crochetin'})}"
    >
      Ver todos os materiais →
    </a>
  </div>
</BaseLayout>

<style>
  .page-header {
    display: grid;
    grid-template-columns: 48px 1fr 48px;
    align-items: center;
    gap: 1rem;
    margin-bottom: var(--spacing-xl);
  }

  .back-button {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-beige), var(--color-taupe));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
    border: none;
  }

  .back-button:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-md);
    color: white;
    opacity: 0.95;
  }

  .header-text {
    text-align: center;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-black);
    margin: 0 0 0.25rem;
    line-height: 1.2;
  }

  .page-subtitle {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin: 0;
  }

  .kits-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .kit-card {
    background: white;
    border-radius: 1.25rem;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .kit-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .kit-icon {
    font-size: 2rem;
    flex-shrink: 0;
    width: 48px;
    text-align: center;
  }

  .kit-info {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .kit-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: #3E2F25;
    margin: 0;
  }

  .kit-description {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.4;
  }

  .cta-section {
    background: linear-gradient(135deg, #3E2F25, #5a4236);
    border-radius: 1.5rem;
    padding: 1.5rem 1.25rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: var(--shadow-md);
  }

  .cta-text {
    font-family: var(--font-sans);
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    margin: 0;
  }

  .cta-btn {
    display: block;
    background: #be996f;
    color: white;
    text-decoration: none;
    padding: 1rem 2rem;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    transition: background 0.2s, transform 0.2s;
    box-shadow: 0 4px 16px rgba(190, 153, 111, 0.35);
  }

  .cta-btn:hover {
    background: #a8845a;
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .page-header {
      grid-template-columns: 40px 1fr 40px;
    }

    .page-title {
      font-size: 1.5rem;
    }
  }
</style>
