---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada - Crochetin" description="Esta página não existe.">
  <div class="not-found">
    <p class="not-found-emoji">🧶</p>
    <h1 class="not-found-title">Ops, nada por aqui!</h1>
    <p class="not-found-text">Esta página não existe ou foi movida.</p>
    <a href="/" class="not-found-btn">Voltar ao início</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    gap: 1rem;
    text-align: center;
    padding: 2rem;
  }

  .not-found-emoji {
    font-size: 4rem;
    margin: 0;
  }

  .not-found-title {
    font-family: var(--font-display);
    font-size: 2rem;
    color: #3E2F25;
    margin: 0;
  }

  .not-found-text {
    font-family: var(--font-sans);
    color: var(--text-secondary);
    font-size: 1rem;
    margin: 0;
  }

  .not-found-btn {
    margin-top: 0.5rem;
    display: inline-block;
    padding: 0.85rem 2rem;
    background: #be996f;
    color: white;
    text-decoration: none;
    border-radius: 9999px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .not-found-btn:hover {
    background: #a8845a;
  }
</style>
